<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/564/564419.png">
    <title>iLegacy OS</title>
    <style>
        * { -webkit-tap-highlight-color: rgba(0,0,0,0); box-sizing: border-box; }
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #000; font-family: "Helvetica Neue", Helvetica; }
        
        /* Contenedor de la App */
        #main-wrapper {
            width: 1024px; height: 768px; /* Resolución nativa iPad Mini 1 */
            background: url('https://wallpaperaccess.com/full/1150436.jpg') no-repeat center center;
            background-size: cover;
            position: relative;
        }

        /* Reloj */
        .header { text-align: center; padding-top: 60px; color: white; }
        #clock { font-size: 100px; font-weight: 200; margin: 0; }
        #date { font-size: 22px; opacity: 0.8; margin-top: -10px; }

        /* Grid de Iconos */
        .grid { display: -webkit-flex; -webkit-flex-wrap: wrap; -webkit-justify-content: center; padding: 40px; }
        .icon { width: 120px; text-align: center; margin: 15px; color: white; text-decoration: none; cursor: pointer; }
        .icon img { width: 75px; height: 75px; border-radius: 18px; display: block; margin: 0 auto 8px; box-shadow: 0 5px 15px rgba(0,0,0,0.5); }
        .icon span { font-size: 13px; font-weight: 500; text-shadow: 0 2px 4px #000; }

        /* VISOR DE APLICACIONES (El "Navegador" interno) */
        #app-viewer {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: white; display: none; z-index: 100;
        }
        #web-frame { width: 100%; height: 100%; border: none; }
        
        /* Botón Flotante para Salir (Estilo iOS) */
        #btn-close {
            position: absolute; bottom: 20px; left: 50%; margin-left: -25px;
            width: 50px; height: 50px; background: rgba(0,0,0,0.5);
            border: 2px solid white; border-radius: 50%; color: white;
            font-size: 30px; line-height: 45px; text-align: center;
            z-index: 200; display: none; cursor: pointer;
        }
    </style>
</head>
<body>

<div id="main-wrapper">
    <div class="header">
        <div id="clock">00:00</div>
        <div id="date">...</div>
    </div>

    <div class="grid">
        <div class="icon" onclick="openApp('https://mbasic.facebook.com')">
            <img src="https://cdn-icons-png.flaticon.com/512/124/124010.png"><span>FB Lite</span>
        </div>
        <div class="icon" onclick="openApp('https://m.youtube.com/?app=m&persist_app=1')">
            <img src="https://cdn-icons-png.flaticon.com/512/1384/1384060.png"><span>YouTube</span>
        </div>
        <div class="icon" onclick="openApp('https://baize.ai/chat')">
            <img src="https://upload.wikimedia.org/wikipedia/commons/0/04/ChatGPT_logo.svg"><span>AI Chat</span>
        </div>
        <div class="icon" onclick="openApp('https://web.telegram.org/k/')">
            <img src="https://cdn-icons-png.flaticon.com/512/2111/2111646.png"><span>Telegram</span>
        </div>
        <div class="icon" onclick="openApp('https://www.google.com/search?gbv=1')">
            <img src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png"><span>Google</span>
        </div>
        <div class="icon" onclick="openApp('https://mail.google.com/mail/u/0/h/')">
            <img src="https://cdn-icons-png.flaticon.com/512/5968/5968534.png"><span>Gmail</span>
        </div>
        <div class="icon" onclick="openApp('https://www.google.com/maps/?force=lite')">
            <img src="https://cdn-icons-png.flaticon.com/512/854/854878.png"><span>Maps Lite</span>
        </div>
        <div class="icon" onclick="openApp('https://radio.garden')">
            <img src="https://cdn-icons-png.flaticon.com/512/2301/2301145.png"><span>Radio</span>
        </div>
    </div>
</div>

<div id="app-viewer">
    <iframe id="web-frame" src=""></iframe>
</div>
<div id="btn-close" onclick="closeApp()">×</div>

<script>
    // Reloj ES5 (Compatible con iOS 9)
    function updateClock() {
        var now = new Date();
        var h = now.getHours(), m = now.getMinutes();
        if (h < 10) h = "0" + h; if (m < 10) m = "0" + m;
        document.getElementById('clock').innerText = h + ":" + m;
        var days = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];
        var months = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
        document.getElementById('date').innerText = days[now.getDay()] + ", " + now.getDate() + " de " + months[now.getMonth()];
    }
    setInterval(updateClock, 1000); updateClock();

    // Lógica del "Navegador Independiente"
    function openApp(url) {
        document.getElementById('web-frame').src = url;
        document.getElementById('app-viewer').style.display = 'block';
        document.getElementById('btn-close').style.display = 'block';
    }

    function closeApp() {
        document.getElementById('app-viewer').style.display = 'none';
        document.getElementById('btn-close').style.display = 'none';
        document.getElementById('web-frame').src = ''; // Limpia memoria
    }
</script>

</body>
</html>
